# Flask configuration
SECRET_KEY=your-super-secret-flask-key
FLASK_ENV=development
FLASK_APP=run.py

# Database configuration
# For MySQL: mysql+pymysql://user:password@host:port/database_name
# For SQLite fallback (default if mysql is not configured/unreachable): sqlite:///rxverify.db
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/rxverify

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key
JWT_ACCESS_TOKEN_EXPIRES=86400  # 1 day in seconds

# File Upload Settings
UPLOAD_FOLDER=Uploads
MAX_CONTENT_LENGTH=16777216  # 16 MB max upload

# Tesseract OCR settings
# Path to the Tesseract executable (adjust for your OS)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
